# =============================================================================
# MeetingMind — Root Environment Example
# Copy to .env and fill in values. Never commit .env to source control.
# =============================================================================

# ---------------- App --------------------------------------------------------
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000

# ---------------- Database ---------------------------------------------------
DATABASE_URL=postgresql+asyncpg://meetingmind:meetingmind@localhost:5432/meetingmind
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------- Redis / Celery ---------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------- Auth (NextAuth + Google OAuth) -----------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------- AI (cloud — optional, falls back to Ollama if blank) -------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small

# ---------------- Ollama (local fallback) ------------------------------------
# Install: https://ollama.com — then: ollama pull llama3.1:8b && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---------------- Recall.ai --------------------------------------------------
# Sign up at https://www.recall.ai — API key from the dashboard
RECALL_API_KEY=
RECALL_WEBHOOK_SECRET=
RECALL_BASE_URL=https://api.recall.ai/api/v1

# ---------------- Composio (integrations) ------------------------------------
COMPOSIO_API_KEY=

# ---------------- AWS S3 (transcript storage) --------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=meetingmind-transcripts
S3_REGION=us-east-1

# ---------------- Frontend (Next.js public) ----------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------- Observability ----------------------------------------------
SENTRY_DSN=

# ---------------- Webhooks ---------------------------------------------------
# Public URL where Recall.ai can POST events (use ngrok in local dev)
API_BASE_URL=http://localhost:8000
